<view class="bar-chart-container">
  <view class="chart-title" wx:if="{{title}}">{{title}}</view>
  <view class="chart-wrapper" bindtap="onTap">
    <canvas 
      canvas-id="canvas"
      class="bar-canvas"
      style="height: {{height}}px;"
      width="{{canvasWidth}}"
      height="{{canvasHeight}}"
    ></canvas>
  </view>
</view> 