.am-root {
  position: relative;
  overflow: hidden; /* 组件内裁剪，避免缩放导致外溢 */
  box-sizing: border-box;
}

.am-preload {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  overflow: hidden;
  opacity: 0;
  left: -9999rpx;
  top: -9999rpx;
}

.am-preload-img {
  width: 1rpx;
  height: 1rpx;
}

.am-stack {
  position: relative;
  width: 100%;
  z-index: 1;
}

.am-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  transform-origin: center;
  will-change: transform, opacity;
}

.am-layer-top {
  z-index: 2;
}

/* 与 club-detail-panel「最近活动」地图相同的左 / 下 / 左下角淡出 */
.am-fade-left {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 250rpx;
  z-index: 3;
  background: linear-gradient(90deg, rgb(255, 255, 255) 0%, rgba(248, 248, 248, 0.85) 35%, rgba(248, 248, 248, 0.4) 70%, rgba(248, 248, 248, 0) 100%);
  pointer-events: none;
}

.am-fade-bottom {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 250rpx;
  z-index: 3;
  background: linear-gradient(0deg, rgb(255, 255, 255) 0%, rgba(248, 248, 248, 0.85) 35%, rgba(248, 248, 248, 0.4) 70%, rgba(248, 248, 248, 0) 100%);
  pointer-events: none;
}

.am-fade-corner {
  position: absolute;
  left: -60rpx;
  bottom: -60rpx;
  width: 400rpx;
  height: 400rpx;
  z-index: 4;
  background: radial-gradient(closest-side, rgb(255, 255, 255) 0%, rgba(248, 248, 248, 0.85) 45%, rgba(248, 248, 248, 0.35) 75%, rgba(248, 248, 248, 0) 100%);
  pointer-events: none;
}


